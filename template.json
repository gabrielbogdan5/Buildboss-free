{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://gabrielbogdan5.github.io/Buildboss-free/icon-192x192.png",
                  "size": "Small",
                  "style": "RoundedCorners"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${appName}",
                  "weight": "Bolder",
                  "size": "Medium",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "${tagline}",
                  "size": "Small",
                  "isSubtle": true,
                  "wrap": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "📋 ${auditCount} Audits",
                  "size": "Small",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "🔧 ${talkCount} Toolbox Talks",
                  "size": "Small",
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "📅 ${dabCount} Briefings",
                  "size": "Small",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "⚠️ ${incidentCount} Incidents",
                  "size": "Small",
                  "wrap": true
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "ActionSet",
      "actions": [
        {
          "type": "Action.OpenUrl",
          "title": "New Audit",
          "url": "https://gabrielbogdan5.github.io/Buildboss-free/?section=audit",
          "style": "positive"
        },
        {
          "type": "Action.OpenUrl",
          "title": "New Incident",
          "url": "https://gabrielbogdan5.github.io/Buildboss-free/?section=incident",
          "style": "destructive"
        }
      ]
    }
  ]
}
